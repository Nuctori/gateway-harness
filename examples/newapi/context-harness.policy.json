{
  "version": "0.1",
  "programs": [
    {
      "name": "newapi-coding-harness",
      "models": ["*"],
      "tags": ["domain:coding", "adapter:newapi"],
      "steps": [
        {
          "hook": "request.before_upstream",
          "when": {
            "model_matches": "*"
          },
          "do": [
            {
              "action": "context.inject",
              "role": "system",
              "position": "after_existing_system",
              "reason": "preserve harness context",
              "text": "Preserve user intent and prior architecture decisions."
            }
          ]
        },
        {
          "hook": "responses.compact.before_upstream",
          "when": {
            "model_matches": "*"
          },
          "do": [
            {
              "action": "context.inject_ledger_summary",
              "role": "system",
              "position": "after_existing_system",
              "ledger_ref": "ledger://project_gateway_harness/session_codex_context_harness",
              "artifact_refs": ["artifact_compact_summary_1"],
              "reason": "compact ledger sentinel",
              "text": "Project memory sentinel: preserve explicit user goals, architecture decisions, deployment constraints, open PR status, and unresolved tasks from the referenced ledger summary."
            }
          ]
        }
      ]
    }
  ]
}
